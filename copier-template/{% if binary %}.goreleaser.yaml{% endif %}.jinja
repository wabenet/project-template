---
version: 2
project_name: {{ project_name }}

before:
  hooks:
    - go mod download
    - go generate ./...

builds:
  - id: main
    main: ./cmd/{{ binary_name }}
    env: ["CGO_ENABLED=0"]
    goos: [linux, darwin]

archives:
  - ids: [main]
    formats: [binary]
    name_template: "{{ '{{' }} .Binary {{ '}}' }}_{{ '{{' }} .Os {{ '}}' }}_{{ '{{' }} .Arch {{ '}}' }}"

checksum:
  name_template: 'checksums.txt'

snapshot:
  version_template: "{{ '{{' }} .Tag {{ '}}' }}-next"

changelog:
  sort: asc
  filters:
    exclude:
      - '^docs:'
      - '^test:'
      - '^chore:'
